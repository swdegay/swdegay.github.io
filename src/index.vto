<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{{ title }}</title>
    <meta name="description" content="{{ description }}">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="{{ url }}">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono&display=swap" rel="stylesheet">

    <link rel="icon" href="favicon.svg">

    <script>{{ include "js/theme-preference-preload.js" }}</script>
    <style>
      {{ include "css/fadein.css" }}
      {{ include "css/flexbox.css" }}

      :root {
        --theme-toggle-label-light: url('{{ dark_mode_icon }}');
        --theme-toggle-label-dark: url('{{ light_mode_icon }}');
      }
      {{ include "css/theme.css" }}

      {{ include "css/main.css" }}
    </style>
  </head>
  <body class="flex flex-col justify-between">
    <div class="content">
      <main>
        {{ include "templates/about.vto" }}
      </main>
    </div>
    {{ include "templates/theme-toggle.vto" }}
    <script>{{ include "js/theme-preference.js" }}</script>
    <script>{{ include "js/timestamp-formatter.js" }}</script>
  </body>
</html>
