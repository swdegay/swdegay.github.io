{
  "name": "Deno Dev Container",
  "image": "denoland/deno:debian",
  "customizations": {
    "vscode": {
      "extensions": [
        "denoland.vscode-deno"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true,
        "[typescript]": {
          "editor.defaultFormatter": "denoland.vscode-deno"
        },
        "[handlebars]": {
          "editor.formatOnSave": false
        },
        "editor.tabSize": 2,
        "files.associations": {
          "*.eta": "handlebars",
          "*.html": "handlebars"
        }
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "mounts": ["source=/etc/localtime,target=/etc/localtime,type=bind,readonly"],
  "postCreateCommand": "deno install"
}
