{
  "tasks": {
    "build": "deno -P=build-permissions build.ts",
    "test": "deno test tests/",
    "check": "deno fmt && deno lint && deno test",
    "clean": "rm -rf dist/"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["src/"]
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "exclude": ["src/"]
  },
  "imports": {
    "@/": "./",
    "@bgub/eta": "jsr:@bgub/eta@^4.5.1",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/random": "jsr:@std/random@^0.1.5",
    "html-minifier-terser": "npm:html-minifier-terser@^7.2.0",
    "svgo": "npm:svgo@^4.0.1"
  },
  "permissions": {
    "build-permissions": {
      "env": [
        "COMMIT_HASH",
        "HTTP_PROXY",
        "http_proxy"
      ],
      "read": {
        "allow": ["./data", "./dist", "./src"]
      },
      "write": {
        "allow": ["./dist"]
      }
    }
  }
}
